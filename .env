# ============================================================
#   ENVIRONMENT VARIABLES — Customer Segmentation Project
# ============================================================

# ---------------------------------------------------------------
# NGROK AUTHENTICATION TOKEN
# ---------------------------------------------------------------
# Used to expose the Streamlit app to the internet via a public URL.
#
# HOW TO GET YOUR NGROK AUTH TOKEN:
#   1. Sign up / Log in at https://dashboard.ngrok.com
#   2. Go to "Your Authtoken" section in the dashboard
#   3. Copy your token and paste it below (replace the placeholder)
# ---------------------------------------------------------------

NGROK_AUTH_TOKEN=your_ngrok_auth_token_here

# ---------------------------------------------------------------
# STREAMLIT CONFIGURATION (optional)
# ---------------------------------------------------------------
# Uncomment and set if you want to run on a specific port
# STREAMLIT_PORT=8501